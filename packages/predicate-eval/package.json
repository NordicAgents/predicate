{
  "name": "predicate-eval",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src tests --max-warnings 0",
    "demo": "tsx src/load-corpus.ts && tsx src/ask.ts",
    "ontology-check": "tsx src/ontology-ci.ts",
    "eval": "tsx src/eval.ts",
    "tier2": "tsx src/tier2.ts"
  },
  "dependencies": {
    "predicate-agent": "workspace:^",
    "predicate-mcp": "workspace:*",
    "predicate-reasoner": "workspace:*",
    "tsx": "^4.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
