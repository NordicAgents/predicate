{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/gemini-cli/session-start.sh\""
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/gemini-cli/session-start.sh\""
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/gemini-cli/stop.sh\""
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/gemini-cli/pre-compact.sh\""
          }
        ]
      }
    ]
  }
}
